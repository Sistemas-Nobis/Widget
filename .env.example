# Variables de entorno del proyecto Widget
# Copiar este archivo a .env y completar los valores.
# .env se carga automáticamente vía python-dotenv en config/settings.py

# Puerto del servidor (usado por manage.py runserver)
PORT=8000

# Token de autenticación para la API de bonificaciones.
# Se envía en el header "X-API-Token".
# Endpoint: https://bonificaciones.nobis.com.ar/api/individuales/<grupo>/insertar
BONIF_API_TOKEN=
