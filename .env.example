# Variables de entorno del proyecto Widget
# Copiar este archivo a .env y completar los valores.
# .env se carga automáticamente vía python-dotenv en config/settings.py

# Puerto del servidor (usado por manage.py runserver)
PORT=8000

# Token de autenticación para la API de bonificaciones.
# Se envía en el header "X-API-Token".
# Endpoint: https://bonificaciones.nobis.com.ar/api/individuales/<grupo>/insertar
BONIF_API_TOKEN=

# ==========================================================================
# Django
# ==========================================================================
# En producción: generar una SECRET_KEY nueva y poner DJANGO_DEBUG=False.
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True

# ==========================================================================
# Autenticación Azure AD (MSAL)
# ==========================================================================
# Flag maestro del gate: con False el gate está dormido (deploy seguro / rollback instantáneo).
WIDGET_AUTH_ENABLED=False
# El widget corre embebido como iframe cross-site en prod. En dev local dejar False.
WIDGET_CROSS_SITE=False

# App Registration (Entra ID). Los pasa quien administra el tenant.
MSAL_CLIENT_ID=
MSAL_TENANT_ID=
MSAL_CLIENT_SECRET=
# Opcional; si se omite se arma con el tenant id.
MSAL_AUTHORITY=
# redirect_uri PÚBLICO. Debe estar registrado en la App Registration.
#   prod: https://widget.nobis.com.ar/widget/auth/callback
#   dev : http://localhost:8000/auth/callback
MSAL_REDIRECT_URI=http://localhost:8000/auth/callback

# ==========================================================================
# RBAC / superadmin
# ==========================================================================
# Break-glass anti-lockout: UPNs superadmin separados por coma (bootstrap sin depender de la DB).
WIDGET_SUPERADMINS=
# Grupo Entra dedicado de superadmins (objectId GUID). Opcional; se resuelve del claim 'groups'.
WIDGET_SUPERADMIN_GROUP_ID=
